    }

    // Profissões
    const profissoes = ["Pedreiro", "Carpinteiro", "Armador", "Eletricista", "Encanador", "Pintor", "Ajudante", "Servente"];
    
    // Estado global das atividades
    let atividades = [...atividadesBase];
    let selectedRows = new Array(atividades.length).fill(true);
    
    // Render tabela principal
    function renderTabela() {
        const tbody = document.getElementById("activity-tbody");
        tbody.innerHTML = "";
        atividades.forEach((act, idx) => {
            const tr = document.createElement("tr");
            const tdSel = document.createElement("td");
            const chk = document.createElement("input");
            chk.type = "checkbox";
            chk.classList.add("select-check");
            chk.checked = selectedRows[idx] !== false;
            chk.addEventListener("change", (e) => { selectedRows[idx] = e.target.checked; });
            tdSel.appendChild(chk);
            tr.appendChild(tdSel);
            const tdNome = document.createElement("td"); tdNome.innerText = act.nome; tdNome.style.textAlign="left"; tr.appendChild(tdNome);
            const tdUn = document.createElement("td"); tdUn.innerText = act.unid; tr.appendChild(tdUn);
            const tdQtd = document.createElement("td");
            const inputQtd = document.createElement("input");
            inputQtd.type = "number";
            inputQtd.value = act.qtd;
            inputQtd.step = "any";
            inputQtd.classList.add("quant-input");
            inputQtd.addEventListener("change", (e) => { act.qtd = parseFloat(e.target.value) || 0; });
            tdQtd.appendChild(inputQtd);
            tr.appendChild(tdQtd);
            const tdIdx = document.createElement("td"); tdIdx.innerText = act.indice.toFixed(3); tr.appendChild(tdIdx);
            const tdComp = document.createElement("td");
            const compText = profissoes.map((p,i) => act.coef[i] > 0 ? `${p}:${act.coef[i].toFixed(2)}` : null).filter(v=>v).slice(0,3).join(", ");
            tdComp.innerText = compText + (act.coef.filter(c=>c>0).length>3?"...":"");
            tdComp.style.fontSize="0.7rem";
            tr.appendChild(tdComp);
            tbody.appendChild(tr);
        });
    }
    
    function renderEquipeInputs() {
        const container = document.getElementById("crew-inputs");
        container.innerHTML = "";
        profissoes.forEach(prof => {
            const div = document.createElement("div");
            div.className = "resource-item";
            let defaultVal = (prof === "Pedreiro" ? 1 : prof === "Carpinteiro" ? 1 : prof === "Servente" ? 2 : 1);
            div.innerHTML = `<span class="resource-label">${prof}</span>
                            <input type="number" id="crew_${prof}" class="resource-input" value="${defaultVal}" step="0.5" min="0">`;
            container.appendChild(div);
        });
    }
    
    // Cálculo principal
    function calcularPlanejamento() {
        const crew = {};
        profissoes.forEach(prof => {
            let val = parseFloat(document.getElementById(`crew_${prof}`).value);
            crew[prof] = (isNaN(val) || val<0) ? 0 : val;
        });
        const jornada = parseFloat(document.getElementById("jornada").value) || 8;
        let eficiencia = parseFloat(document.getElementById("eficiencia").value);
        if(isNaN(eficiencia) || eficiencia<=0) eficiencia = 100;
        const fatorHora = 100 / eficiencia; // se eficiencia 80% -> fator 1.25 (mais horas)
        
        const atvsSelecionadas = atividades.filter((_, idx) => selectedRows[idx] === true);
        if(atvsSelecionadas.length === 0) {
            document.getElementById("resumo-global").innerHTML = "<span style='color:#b33'>⚠️ Selecione ao menos uma atividade.</span>";
            document.getElementById("duracao-total").innerText = "---";
            return;
        }
        
        let totalHHGeral = {};
        profissoes.forEach(p => totalHHGeral[p] = 0);
        let atividadesDetalhe = [];
        
        for(let act of atvsSelecionadas) {
            const somaCoef = act.coef.reduce((a,b)=>a+b,0);
            let HHtotal = act.qtd * act.indice;
            HHtotal = HHtotal * fatorHora; // aplica eficiência
            if(HHtotal === 0) continue;
            let profsHH = {};
            for(let i=0; i<profissoes.length; i++) {
                let peso = act.coef[i];
                let HHprof = (somaCoef > 0) ? HHtotal * (peso / somaCoef) : (peso>0? HHtotal : 0);
                profsHH[profissoes[i]] = HHprof;
                totalHHGeral[profissoes[i]] += HHprof;
            }
            atividadesDetalhe.push({ nome: act.nome, HHtotal, profsHH, qtd:act.qtd, unid:act.unid });
        }
        
        let duracaoSequencial = 0;
        let detalhesHtml = "<ul>";
        for(let act of atividadesDetalhe) {
            let maxDias = 0;
            for(let prof of profissoes) {
                let hhProf = act.profsHH[prof] || 0;
                let numTrab = crew[prof] || 0;
                if(hhProf > 0 && numTrab > 0) {
                    let dias = hhProf / (numTrab * jornada);
                    if(dias > maxDias) maxDias = dias;
                } else if(hhProf > 0 && numTrab === 0) {
                    maxDias = Infinity;
                }
            }
            if(!isFinite(maxDias)) {
                detalhesHtml += `<li style="color:#c33">⚠️ ${act.nome}: sem mão de obra necessária → inviável</li>`;
            } else {
                detalhesHtml += `<li>📌 ${act.nome} (${act.qtd.toFixed(2)} ${act.unid}) → duração: <strong>${maxDias.toFixed(2)} dias</strong> (HH base: ${(act.HHtotal/fatorHora).toFixed(1)}h → c/ eficiência: ${act.HHtotal.toFixed(1)}h)</li>`;
                duracaoSequencial += maxDias;
            }
        }
        detalhesHtml += "</ul>";
        
        let resumoHTML = `<div style="font-size:0.85rem">📊 TOTAL HH por profissão (ajustado eficiência):<br/>`;
        for(let prof of profissoes) {
            if(totalHHGeral[prof]>0) resumoHTML += `▪️ ${prof}: ${totalHHGeral[prof].toFixed(1)} h-homem<br/>`;
        }
        const equipeAtual = profissoes.map(p => `${p}: ${crew[p]}`).join(" | ");
        resumoHTML += `<div style="margin-top:6px">👥 Equipe atual: ${equipeAtual}<br>⚙️ Eficiência: ${eficiencia}% (fator ${fatorHora.toFixed(2)})</div>`;
        
        let recomendacao = "<div style='background:#e2eaf1; border-radius:16px; padding:10px; margin-top:8px'><strong>💡 Sugestão de quantitativo (base média)</strong><br/>";
        let diasRef = duracaoSequencial > 0 ? duracaoSequencial : 20;
        for(let prof of profissoes) {
            let hh = totalHHGeral[prof];
            if(hh > 0) {
                let sugestao = Math.max(1, Math.ceil(hh / (diasRef * jornada) * 0.9));
                recomendacao += `${prof}: ≈ ${sugestao} | `;
            }
        }
        recomendacao += "</div>";
        
        document.getElementById("resumo-global").innerHTML = resumoHTML;
        document.getElementById("duracao-total").innerHTML = duracaoSequencial.toFixed(2) + " dias (sequencial)";
        document.getElementById("detalhe-atividade").innerHTML = detalhesHtml;
        document.getElementById("recomendacao-equipe").innerHTML = recomendacao;
    }
    
    function addCustomActivity() {
        const nome = document.getElementById("new-act-name").value.trim();
        const unid = document.getElementById("new-act-unit").value.trim();
        let qtd = parseFloat(document.getElementById("new-act-quant").value);
        let indice = parseFloat(document.getElementById("new-act-index").value);
        if(!nome || !unid || isNaN(qtd) || isNaN(indice) || qtd<=0 || indice<=0) {
            alert("Preencha nome, unidade, quantidade e índice válidos.");
            return;
        }
        const coefPadrao = [0.4, 0, 0, 0, 0, 0, 0, 0.6];
        const nova = { nome, unid, qtd, indice, coef: coefPadrao.slice() };
        atividades.push(nova);
        selectedRows.push(true);
        renderTabela();
        document.getElementById("new-act-name").value = "";
        document.getElementById("new-act-unit").value = "";
        document.getElementById("new-act-quant").value = "1";
        document.getElementById("new-act-index").value = "0.5";
    }
    
    // Eventos de calibração
    function initCalibracao() {
        const chapiscoSelect = document.getElementById("chapiscoMethod");
        chapiscoSelect.addEventListener("change", () => aplicarMetodoChapisco(chapiscoSelect.value));
        aplicarMetodoChapisco(chapiscoSelect.value); // aplica o padrão (manual)
        document.getElementById("calcular-planejamento").addEventListener("click", calcularPlanejamento);
        document.getElementById("add-custom-btn").addEventListener("click", addCustomActivity);
    }
    
    renderTabela();
    renderEquipeInputs();
    initCalibracao();
</script>
</body>
</html>
